{
  "name": "ftth-gis-planner",
  "version": "1.0.0",
  "description": "Professional fiber optic route planning and infrastructure design",
  "author": "FTTH Planner",
  "license": "MIT",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "npx serve . --listen 3000",
    "dev:electron": "electron .",
    "build:android": "npx cap sync android && npx cap run android",
    "build:ios": "npx cap sync ios && npx cap run ios",
    "build:win": "npx electron-builder --win",
    "build:mac": "npx electron-builder --mac",
    "build:linux": "npx electron-builder --linux",
    "docker:build": "docker build -t ftth-planner .",
    "docker:run": "docker run -p 8080:80 ftth-planner",
    "cap:add:android": "npx cap add android",
    "cap:add:ios": "npx cap add ios",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios"
  },
  "dependencies": {
    "@capacitor/android": "^6.1.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.1.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/geolocation": "^6.0.0",
    "@capacitor/ios": "^6.1.0",
    "@capacitor/share": "^6.0.0",
    "@capacitor/splash-screen": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "electron": "^42.1.0",
    "electron-builder": "^26.8.1",
    "serve": "^14.2.3"
  },
  "build": {
    "appId": "com.ftthplanner.app",
    "productName": "FTTH GIS Planner",
    "directories": {
      "output": "dist/desktop"
    },
    "files": [
      "index.html",
      "manifest.json",
      "sw.js",
      "assets/**/*",
      "electron/**/*"
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
